# ── Ostja Bot — seadistus ──────────────────────────────────────────────────
# Kopeeri see fail: cp .env.example .env
# Täida oma andmetega. NB: .env faili EI lisa GitHubi (on .gitignore-is)

# ── Telegram ───────────────────────────────────────────────────────────────
# Hangi @BotFather käest: /newbot → Anna nimi → Saa token
TELEGRAM_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# Sinu Telegrami kasutaja ID (bot vastab ainult sulle)
# Hangi: kirjuta Telegramis @userinfobot → saad oma ID
ALLOWED_CHAT_ID=123456789

# ── Asukoht ────────────────────────────────────────────────────────────────
# Tallinn (Viru väljak) — muuda vastavalt
LAT=59.4370
LON=24.7536
CITY=tallinn

# ── Wolt (valikuline — ainult automaatseks tellimiseks) ────────────────────
# Ilma tokenita töötab otsing, aga tellimust ei esitata automaatselt.
# Tokeni hankimise juhend: vt README.md → "Wolt tokeni hankimine"
WOLT_TOKEN=

# ── Bolt Food (valikuline — ainult automaatseks tellimiseks) ───────────────
# Sama mis Wolt — tokenita töötab otsing
BOLT_TOKEN=
BOLT_REFRESH_TOKEN=
